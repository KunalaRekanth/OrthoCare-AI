{
  "name": "ortho-app-root",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace=@ortho/web",
    "dev:mobile": "npm run dev --workspace=@ortho/mobile",
    "build:web": "npm run build --workspace=@ortho/web",
    "build:mobile": "npm run build --workspace=@ortho/mobile",
    "test:e2e": "npm run test:e2e --workspace=@ortho/web"
  }
}
